# Copy to .env (gitignored). Dev defaults only — never use these values outside local.

# ---- Postgres (Docker Compose) ----
POSTGRES_USER=sahahr_owner
POSTGRES_PASSWORD=sahahr_dev_pw
POSTGRES_DB=sahahr
POSTGRES_PORT=5544
SAHAHR_APP_PASSWORD=sahahr_app_pw

# ---- Redis ----
REDIS_PORT=6380

# ---- API: runtime connection uses the RLS-bound app role ----
ConnectionStrings__Default=Host=localhost;Port=5544;Database=sahahr;Username=sahahr_app;Password=sahahr_app_pw
# ---- API: migrations use the owner role (DDL privileges) ----
ConnectionStrings__Migrator=Host=localhost;Port=5544;Database=sahahr;Username=sahahr_owner;Password=sahahr_dev_pw

# ---- Redis connection ----
ConnectionStrings__Redis=localhost:6380

# ---- JWT (dev only — replace with IdP/Keycloak per §7) ----
Jwt__Issuer=https://dev.sahahr.local
Jwt__Audience=sahahr-api
Jwt__SigningKey=dev-only-change-me-must-be-at-least-32-characters-long
