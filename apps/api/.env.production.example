# API production env (Render dashboard). Copy values into Render — DO NOT commit real secrets.
# Connection strings point at Neon; use the DIRECT endpoint (not -pooler) — RLS uses a session GUC.

ASPNETCORE_ENVIRONMENT=Production
# PORT is injected by Render; no need to set it.

# Neon app role (RLS-bound) — the runtime connection:
ConnectionStrings__Default=Host=<neon-host>;Database=neondb;Username=sahahr_app;Password=<app-pw>;SSL Mode=Require;Trust Server Certificate=true
# Neon owner role — migrations + RLS-exempt background work:
ConnectionStrings__Migrator=Host=<neon-host>;Database=neondb;Username=neondb_owner;Password=<owner-pw>;SSL Mode=Require;Trust Server Certificate=true

# JWT validation (HS256). NOTE: this is the dev-issuer model — see DEPLOY.md "Auth gate".
Jwt__Issuer=https://sahahr-api.onrender.com
Jwt__Audience=sahahr-api
Jwt__SigningKey=<generate a random string of at least 32 characters>
# For production OIDC (Keycloak), set Jwt__Authority instead and drop the dev signing key (docs/AUTH.md):
# Jwt__Authority=https://<your-idp>/realms/sahahr

# PII field encryption at rest (§8.3) — base64-encoded 32-byte AES-256 key. REQUIRED: the API fails
# fast at startup without it. Generate: openssl rand -base64 32
Encryption__DataKey=<base64-encoded 32-byte key>

